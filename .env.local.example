################################################################################
# Local development template (backend/.env)
#
# 推荐用途：
# - 本地跑后端：cd backend && uvicorn app.main:app --reload
# - 不影响部署用的根目录 .env
#
# 用法：
# cp .env.local.example backend/.env
################################################################################

# Required
ARK_API_KEY=your-ark-api-key
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
ARK_ASR_MODE=sauc_v3
ARK_ASR_WS_URL=wss://openspeech.bytedance.com/api/v3/sauc/bigmodel
ARK_ASR_RESOURCE_ID=volc.bigasr.sauc.duration
ARK_ASR_APP_ID=
ARK_ASR_ACCESS_TOKEN=
ARK_ASR_CLUSTER=bigmodel
ARK_ASR_SAMPLE_RATE=24000

# Admin login
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# Auth
JWT_SECRET=local-dev-secret-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Local backend defaults
DATABASE_URL=sqlite:///./ai_interview.db
UPLOAD_DIR=./app/static/uploads

# Models
ARK_STT_MODEL=Doubao-语音识别
ARK_LLM_MODEL=doubao-seed-2-0-mini-260215
ARK_EVAL_MODEL=doubao-seed-2-0-mini-260215
ARK_CHAT_MODEL=doubao-seed-2-0-mini-260215
ARK_DECISION_MODEL=doubao-seed-2-0-mini-260215
ARK_TTS_MODEL=Doubao-语音合成
ARK_TTS_VOICE=zh_female_shuangkuaisisi_moon_bigtts
ARK_TTS_SAMPLE_RATE=24000

# Realtime behavior
REALTIME_STRICT_PROMPT_ENABLED=true
REALTIME_CONTEXT_RESET_MODE=per_main_question
REALTIME_MIN_MAIN_ANSWER_CHARS=12
REALTIME_MAIN_ANSWER_CONFIRM_WORDS=嗯,好,可以,是的,明白,了解,好的,没问题,OK,ok
REALTIME_DECISION_LAYER_ENABLED=true
REALTIME_DECISION_TIMEOUT_MS=5000
REALTIME_DECISION_HISTORY_TURNS=3
REALTIME_DECISION_MAX_CHARS=1200

# Optional test switch
RUN_REALTIME_SMOKE=0
