# Required
OPENAI_API_KEY=your_openai_api_key_here
JWT_SECRET=change-this-jwt-secret
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-admin-password

# Backend runtime
DATABASE_URL=sqlite:////app/data/interview.db
UPLOAD_DIR=/app/app/static/uploads
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Model settings
STT_MODEL=gpt-4o-mini-transcribe
EVAL_LLM_MODEL=gpt-4o-mini
REALTIME_MODEL=gpt-realtime-mini
REALTIME_DECISION_MODEL=gpt-4o-mini

# Realtime behavior
REALTIME_STRICT_PROMPT_ENABLED=true
REALTIME_CONTEXT_RESET_MODE=per_main_question
REALTIME_MIN_MAIN_ANSWER_CHARS=12
REALTIME_MAIN_ANSWER_CONFIRM_WORDS=嗯,好,可以,是的,明白,了解,好的,没问题,OK,ok
REALTIME_DECISION_LAYER_ENABLED=true
REALTIME_DECISION_TIMEOUT_MS=5000
REALTIME_DECISION_HISTORY_TURNS=3
REALTIME_DECISION_MAX_CHARS=1200

# Frontend build-time API base (same-origin in scheme B)
VITE_API_BASE_URL=/api

# Optional PostgreSQL service values (used when starting compose with profile `postgres`)
POSTGRES_DB=ai_interview
POSTGRES_USER=ai_interview
POSTGRES_PASSWORD=change_me
