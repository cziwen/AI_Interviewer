################################################################################
# AI Interviewer environment template
# 用法：
# 1) cp .env.example .env
# 2) 按下面注释修改关键项（至少改 ARK_API_KEY / JWT_SECRET / ADMIN_PASSWORD）
# 3) Docker 部署一般直接用这份；本地 python 运行可按注释调整 DATABASE_URL/UPLOAD_DIR
# 4) 如果你主要是本地开发，建议使用 .env.local.example -> backend/.env
################################################################################

################################################################################
# [A] 必填核心配置（必须修改）
################################################################################

# 火山方舟 API Key（必须）
ARK_API_KEY=your-ark-api-key

# 火山方舟 OpenAI 兼容 HTTP Base URL
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3

# 方舟语音网关 Realtime ASR WebSocket URL
ARK_ASR_WS_URL=wss://ai-gateway.vei.volces.com/v1/realtime?model=bigmodel

# 方舟语音网关资源标识（可空；若控制台给出请填写）
ARK_ASR_RESOURCE_ID=

# JWT 签名密钥（必须）
# 用于后台登录 token 签名；生产环境请设置为高强度随机字符串（建议 32+ 字符）。
# 可用命令生成：openssl rand -hex 32
JWT_SECRET=change-to-a-long-random-secret-at-least-32-chars

# HR 后台账号（建议改）
# ADMIN_USERNAME 可保留 admin，ADMIN_PASSWORD 强烈建议修改。
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-admin-password

################################################################################
# [B] HTTPS 域名配置（生产必须；仅本地开发可先不填）
################################################################################

# 生产部署时的公网域名（给 Caddy 申请 HTTPS 证书使用）
# 示例：interview.example.com
DOMAIN=your.domain.com

# Let's Encrypt 证书通知邮箱（建议真实可用邮箱）
ACME_EMAIL=your-email@example.com

################################################################################
# [C] 后端运行配置
################################################################################

# 数据库连接串：
# - Docker Compose（默认推荐）：sqlite:////app/data/interview.db
# - 本地直接跑后端（uvicorn）：sqlite:///./ai_interview.db
# - PostgreSQL 示例：postgresql://user:pass@localhost:5432/ai_interview
DATABASE_URL=sqlite:////app/data/interview.db

# 上传文件目录：
# - Docker 内推荐：/app/app/static/uploads
# - 本地可改：./app/static/uploads
UPLOAD_DIR=/app/app/static/uploads

# JWT 算法（通常不要改）
ALGORITHM=HS256

# 登录 token 过期时间（分钟）
# 1440 = 24 小时
ACCESS_TOKEN_EXPIRE_MINUTES=1440

################################################################################
# [D] 模型配置（按成本/效果权衡）
################################################################################

# 方舟 STT 模型（按控制台可用模型名/资源名替换）
ARK_STT_MODEL=Doubao-语音识别

# 面试结束后的评估模型
ARK_EVAL_MODEL=doubao-seed-2-0-mini-260215

# 统一 LLM 模型（聊天/评估/决策默认）
ARK_LLM_MODEL=doubao-seed-2-0-mini-260215

# 普通文本对话模型（用于兼容 Chat/Completions 调用）
ARK_CHAT_MODEL=doubao-seed-2-0-mini-260215

# Realtime 决策层模型（判断是否追问/切题等）
ARK_DECISION_MODEL=doubao-seed-2-0-mini-260215

# 语音合成（TTS）
ARK_TTS_MODEL=Doubao-语音合成
ARK_TTS_VOICE=zh_female_meilinvyou_moon_bigtts
ARK_TTS_SAMPLE_RATE=24000

################################################################################
# [E] Realtime 行为参数（一般先保持默认）
################################################################################

# 是否启用严格提示词策略（建议 true）
REALTIME_STRICT_PROMPT_ENABLED=true

# 上下文重置模式：
# - per_main_question: 每个主问题后重置上下文（推荐）
# - none: 不重置
REALTIME_CONTEXT_RESET_MODE=per_main_question

# 判定“主问题已回答”的最小字符数阈值
REALTIME_MIN_MAIN_ANSWER_CHARS=12

# 候选人“确认已回答完”关键词（逗号分隔，中文英文都可）
REALTIME_MAIN_ANSWER_CONFIRM_WORDS=嗯,好,可以,是的,明白,了解,好的,没问题,OK,ok

# 是否启用决策层（建议 true）
REALTIME_DECISION_LAYER_ENABLED=true

# 决策层超时时间（毫秒）
REALTIME_DECISION_TIMEOUT_MS=5000

# 决策层读取历史轮次（越大越耗 token）
REALTIME_DECISION_HISTORY_TURNS=3

# 决策层输入最大字符数（防止上下文过长）
REALTIME_DECISION_MAX_CHARS=1200

################################################################################
# [F] 前端构建配置
################################################################################

# 前端 API 基地址（Vite 构建时读取）
# - Docker/Caddy 同域部署：/api（推荐）
# - 前后端分离部署示例：https://api.example.com
VITE_API_BASE_URL=/api

################################################################################
# [G] PostgreSQL 可选配置（仅在 --with-postgres 或 compose profile=postgres 时用）
################################################################################

# PostgreSQL 数据库名
POSTGRES_DB=ai_interview

# PostgreSQL 用户名
POSTGRES_USER=ai_interview

# PostgreSQL 密码（生产务必修改）
POSTGRES_PASSWORD=change_me

################################################################################
# [H] 测试开关（可选）
################################################################################

# 实时链路烟雾测试开关：
# - 0: 默认关闭（推荐）
# - 1: 运行依赖真实方舟调用的测试
RUN_REALTIME_SMOKE=0
